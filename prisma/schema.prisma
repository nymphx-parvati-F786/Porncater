generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Video {
  id          Int       @id @default(autoincrement())
  title       String    @db.VarChar(500)
  slug        String    @unique
  videoUrl    String
  thumbnail   String
  duration    String
  views       Int       @default(0)
  category    String?
  pornstarId  Int?
  pornstar    Pornstar? @relation(fields: [pornstarId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Pornstar {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  image     String?
  bio       String?  @db.Text
  videos    Video[]
  createdAt DateTime @default(now())
}