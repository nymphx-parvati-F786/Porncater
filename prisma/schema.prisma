generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
  // 🔥 ADVANCED SPEED: Enable Postgres extensions
  previewFeatures = ["postgresqlExtensions"] 
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  // 🔥 ADVANCED SPEED: Load the Trigram extension for lightning-fast text search
  extensions = [pg_trgm] 
}

// ==========================================
// ENUMS
// ==========================================

enum VideoStatus {
  PUBLISHED
  DMCA_TAKEDOWN
  PRIVATE
}

enum RecipientType {
  TO
  CC
  BCC
}

// ==========================================
// CORE MEDIA PLATFORM
// ==========================================

model Video {
  id          Int         @id @default(autoincrement())
  title       String      @db.VarChar(500)
  slug        String      @unique
  videoUrl    String
  thumbnail   String
  duration    String
  views       Int         @default(0)
  likes       Int         @default(0)      // Enables the "Adore" button
  
  category    String?                    // Primary category (e.g., "Hardcore")
  tags        String[]                   // Enables specific tags: ["Anal", "POV", "HD"]
  studio      String?                    // 🔥 AD TARGETING: The channel/network (e.g., "Vixen")
  
  // Many-to-Many: Now a single video can feature 1, 2, or 10 Pornstars
  pornstars   Pornstar[]

  // DMCA HANDLING
  status      VideoStatus @default(PUBLISHED)
  dmcaNotes   String?     @db.Text 
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // === INDEXES FOR MAXIMUM SPEED ===
  @@index([views(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  // 🔥 THE MAGIC BULLET: GIN Trigram index for instant case-insensitive search
  @@index([title(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([studio])
}

model Pornstar {
  id          Int        @id @default(autoincrement())
  name        String
  slug        String     @unique
  avatarUrl   String?    // The square profile picture
  coverImage  String?    // The wide, cinematic banner image
  bio         String?    @db.Text
  
  // Cached Stats for fast loading on the Directory page
  views       Int        @default(0)     // Total accumulated views
  subscribers Int        @default(0)     // The "Subscribe" button count
  tags        String[]                   // Performer traits: ["Brunette", "Petite"]
  
  // Implicit Many-to-Many relation with Videos
  videos      Video[]    
  
  // 🔥 AD TARGETING: Banners that are explicitly targeted at this specific performer
  targetedBanners Banner[]
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([views(sort: Desc)])
}

// ==========================================
// ENTERPRISE AD SERVER NETWORK
// ==========================================

model Sponsor {
  id          String     @id @default(uuid())
  name        String     @unique // e.g., "Mad Cheddar", "Reality Kings", "Blacked"
  isActive    Boolean    @default(true)
  
  campaigns   Campaign[]
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Campaign {
  id          String     @id @default(uuid())
  sponsorId   String
  sponsor     Sponsor    @relation(fields: [sponsorId], references: [id], onDelete: Cascade)
  
  name        String     // e.g., "RevShare Default", "Halloween Promo"
  baseLink    String     // e.g., "https://join.blacked.com/track/MjUzMy..."
  isActive    Boolean    @default(true)
  
  banners     Banner[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Banner {
  id          String     @id @default(uuid())
  campaignId  String
  campaign    Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  
  dimension   String     // e.g., "970x70", "300x250"
  imageUrl    String     // e.g., "https://img-s1-cdn.porncater.com/media/b970x70-a1b2.webp"
  weight      Int        @default(10) // Higher number = shows up more often
  isActive    Boolean    @default(true)

  // 🔥 ADVANCED HYPER-TARGETING 🔥
  targetStudios    String[]   // e.g., ["Vixen", "Tushy"]. If empty, shows globally.
  targetCategories String[]   // e.g., ["VR", "Anal"]. If empty, shows globally.
  targetStars      Pornstar[] // Link directly to performers (Many-to-Many)

  // 🔥 ADDED THIS: Each specific image gets its exact, unique tracking link
  trackingLink String

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([dimension])
  @@index([isActive])
}

// ==========================================
// CUSTOM EMAIL INBOX
// ==========================================

model InboxMessage {
  id               Int       @id @default(autoincrement())

  // ===== IDENTIFIERS =====
  messageId        String?   @unique
  threadId         String?

  // ===== SUBJECT =====
  subject          String    @default("(No Subject)")

  // ===== SENDER =====
  fromName         String?
  fromEmail        String

  // ===== REPLY =====
  replyTo          String?

  // ===== CONTENT =====
  textBody         String?   @db.Text
  htmlBody         String?   @db.Text

  // ===== METADATA =====
  sentAt           DateTime?
  receivedAt       DateTime  @default(now())
  sizeBytes        Int?
  headers          Json?
  hasAttachments   Boolean   @default(false)

  // ===== STATUS =====
  isRead           Boolean   @default(false)
  isStarred        Boolean   @default(false)
  isTrashed        Boolean   @default(false)

  // ===== RELATIONS =====
  recipients       InboxRecipient[]
  attachments      InboxAttachment[]

  @@index([receivedAt(sort: Desc)])
  @@index([fromEmail])
  @@index([subject])
  @@index([isRead])
  @@index([isTrashed])
}

model InboxRecipient {
  id          Int           @id @default(autoincrement())
  type        RecipientType
  name        String?
  email       String
  messageId   Int
  message     InboxMessage  @relation(fields:[messageId], references:[id], onDelete: Cascade)

  @@index([email])
}

model InboxAttachment {
  id          Int           @id @default(autoincrement())
  filename    String
  mimeType    String
  sizeBytes   Int
  storagePath String?
  contentId   String?
  isInline    Boolean       @default(false)
  messageId   Int
  message     InboxMessage  @relation(fields:[messageId], references:[id], onDelete: Cascade)
}